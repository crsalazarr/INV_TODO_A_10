<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Control - Todo a 10.000</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .header {
            background: white;
            border-radius: 20px 20px 0 0;
            padding: 30px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            margin-bottom: 20px;
        }

        .header h1 {
            color: #333;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .header h2 {
            color: #667eea;
            font-size: 18px;
            font-weight: 500;
        }

        .dashboard {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: #667eea;
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #667eea;
        }

        .info-display {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 15px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .info-label {
            font-weight: 600;
            color: #555;
        }

        .info-value {
            font-weight: 700;
            color: #333;
            font-family: 'Courier New', monospace;
        }

        .control-section {
            margin-top: 20px;
            text-align: center;
        }

        .sale-button {
            width: 100%;
            padding: 25px;
            background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
            color: white;
            border: none;
            border-radius: 15px;
            font-size: 24px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 20px;
            box-shadow: 0 10px 20px rgba(76, 175, 80, 0.3);
        }

        .sale-button:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(76, 175, 80, 0.4);
            background: linear-gradient(135deg, #45a049 0%, #4CAF50 100%);
        }

        .sale-button:active {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(76, 175, 80, 0.4);
        }

        .button-label {
            font-size: 16px;
            opacity: 0.9;
            margin-top: 5px;
        }

        .transactions {
            margin-top: 20px;
            max-height: 300px;
            overflow-y: auto;
        }

        .transaction-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 15px;
            margin-bottom: 8px;
            background: #f8f9fa;
            border-radius: 8px;
            border-left: 4px solid #4CAF50;
        }

        .transaction-time {
            font-size: 12px;
            color: #666;
            min-width: 70px;
        }

        .transaction-details {
            flex: 1;
            margin-left: 15px;
        }

        .transaction-type {
            font-weight: 600;
            font-size: 14px;
            color: #2E7D32;
        }

        .transaction-amount {
            font-weight: 700;
            font-family: 'Courier New', monospace;
            color: #2E7D32;
        }

        .total-display {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 25px;
            border-radius: 15px;
            text-align: center;
            margin-top: 20px;
        }

        .total-label {
            font-size: 18px;
            margin-bottom: 10px;
        }

        .total-amount {
            font-size: 36px;
            font-weight: 700;
            font-family: 'Courier New', monospace;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-top: 20px;
        }

        .stat-box {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 10px;
            text-align: center;
            border: 2px solid #e0e0e0;
        }

        .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: #667eea;
            margin-bottom: 5px;
        }

        .stat-label {
            font-size: 12px;
            font-weight: 600;
            color: #666;
        }

        .audit-log {
            background: #fff3e0;
            padding: 15px;
            border-radius: 10px;
            margin-top: 20px;
            max-height: 200px;
            overflow-y: auto;
        }

        .audit-item {
            padding: 8px 0;
            border-bottom: 1px solid #ffe0b2;
            font-size: 13px;
            color: #666;
        }

        .audit-item:last-child {
            border-bottom: none;
        }

        .reset-section {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 2px solid #e0e0e0;
        }

        .button-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .btn-action {
            padding: 12px 20px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
        }

        .btn-reset {
            background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
            color: white;
        }

        .btn-reset:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(244, 67, 54, 0.4);
        }

        .btn-add {
            background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
            color: white;
        }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(33, 150, 243, 0.4);
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            justify-content: center;
            align-items: center;
            z-index: 1000;
        }

        .modal-content {
            background: white;
            padding: 30px;
            border-radius: 15px;
            max-width: 400px;
            width: 90%;
            text-align: center;
        }

        .modal-buttons {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .modal-buttons button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
        }

        .btn-confirm {
            background: #4CAF50;
            color: white;
        }

        .btn-cancel {
            background: #f44336;
            color: white;
        }

        .system-info {
            background: #e3f2fd;
            padding: 10px 15px;
            border-radius: 8px;
            margin-top: 15px;
            font-size: 12px;
            color: #1976d2;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🏪 SISTEMA DE VENTAS TODO A 10.000</h1>
            <h2>Registro Simple - 1 Prenda por Click</h2>
        </div>

        <div class="dashboard">
            <!-- Panel Izquierdo: Control de Ventas -->
            <div class="card">
                <h2 class="card-title">CONTROL DE VENTAS</h2>
                
                <div class="info-display">
                    <div class="info-row">
                        <span class="info-label">Local:</span>
                        <span class="info-value" id="localName">@ViewBag.LocalNombre</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Fecha:</span>
                        <span class="info-value" id="currentDate"></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Encargado:</span>
                        <span class="info-value" id="cashierName">@ViewBag.Nombre @ViewBag.Apellido</span>
                    </div>
                </div>

                <div class="control-section">
                    <button class="sale-button" onclick="registerSale()">
                        🛒 REGISTRAR PRENDA
                        <div class="button-label">+$10.000</div>
                    </button>
                    
                    <div class="system-info">
                        Sistema activo - Cada click registra 1 prenda vendida
                    </div>
                </div>
                
                <div class="reset-section">
                    <div class="button-group">
                        <button class="btn-action btn-reset" onclick="irAReporteDiario()">
                            📊 Finalizar Reporte
                        </button>
                        <button class="btn-action btn-add" onclick="resetSystem()">
                            🔄 Nuevo Día
                        </button>
                    </div>
                </div>
            </div>

            <!-- Panel Derecho: Estadísticas y Registro -->
            <div class="card">
                <h2 class="card-title">ESTADÍSTICAS Y REGISTRO</h2>
                
                <div class="stats-grid">
                    <div class="stat-box">
                        <div class="stat-value" id="totalItems">0</div>
                        <div class="stat-label">PRENDAS VENDIDAS</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-value" id="salesCount">0</div>
                        <div class="stat-label">VENTAS HOY</div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-value">$10.000</div>
                        <div class="stat-label">PRECIO UNITARIO</div>
                    </div>
                </div>

                <div class="transactions">
                    <h3 style="margin-bottom: 15px; color: #667eea;">REGISTRO DE VENTAS:</h3>
                    <div id="transactionList">
                        <!-- Las transacciones aparecerán aquí -->
                    </div>
                </div>

                <div class="total-display">
                    <div class="total-label">TOTAL RECAUDADO HOY</div>
                    <div class="total-amount" id="totalRevenue">$0</div>
                </div>

                <div class="audit-log">
                    <h4 style="color: #f57c00; margin-bottom: 10px;">REGISTRO DE ACTIVIDAD:</h4>
                    <div id="auditLog">
                        <div class="audit-item">Sistema iniciado - Listo para registrar ventas...</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal para confirmar reinicio -->
        <div id="resetModal" class="modal">
            <div class="modal-content">
                <h3>⚠️ CONFIRMAR REINICIO</h3>
                <p>¿Está seguro de que desea reiniciar el sistema?</p>
                <p style="color: #f44336; font-weight: 600; background: #ffebee; padding: 10px; border-radius: 5px;">
                    Se eliminarán todos los registros del día<br>
                    Total actual: <span id="modalTotal">$0</span>
                </p>
                <div class="modal-buttons">
                    <button class="btn-confirm" onclick="confirmReset()">CONFIRMAR REINICIO</button>
                    <button class="btn-cancel" onclick="hideResetModal()">CANCELAR</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Variables del sistema
        let systemState = {
            totalItems: 0,
            availableItems: 100, // Inventario inicial
            salesCount: 0,
            totalRevenue: 0,
            transactionHistory: [],
            auditLog: []
        };

        // Precio por prenda
        const ITEM_PRICE = 10000;

        // Inicializar el sistema
        function initSystem() {
            // Establecer fecha actual
            const now = new Date();
            document.getElementById('currentDate').textContent = 
                now.toLocaleDateString('es-ES', { 
                    weekday: 'long', 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });

            // Cargar datos guardados (si existen)
            loadSavedData();
            
            // Actualizar displays
            updateDisplays();
            
            // Registrar inicio en auditoría
            addAuditLog('Sistema iniciado - Listo para registrar ventas');
        }

        // Registrar una venta (1 prenda)
        function registerSale() {
            if (systemState.availableItems <= 0) {
                alert('❌ INVENTARIO AGOTADO\nNo hay más prendas disponibles para vender.');
                addAuditLog('Intento de venta fallido: Inventario agotado');
                return;
            }

            const timestamp = new Date().toLocaleTimeString();
            
            // Actualizar estado
            systemState.totalItems++;
            systemState.availableItems--;
            systemState.salesCount++;
            systemState.totalRevenue += ITEM_PRICE;
            
            // Agregar a historial
            systemState.transactionHistory.push({
                type: 'sale',
                quantity: 1,
                amount: ITEM_PRICE,
                timestamp: timestamp
            });
            
            // Actualizar displays
            updateDisplays();
            
            // Agregar a registro visual
            addTransactionToDisplay(timestamp);
            
            // Registrar en auditoría
            addAuditLog(`Venta registrada: 1 prenda - $${ITEM_PRICE.toLocaleString()}`);
            
            // Guardar datos
            saveData();
            
            // Efecto visual de confirmación
            showSaleConfirmation();
        }

        // Mostrar confirmación visual de venta
        function showSaleConfirmation() {
            const saleButton = document.querySelector('.sale-button');
            const originalText = saleButton.innerHTML;
            
            // Cambiar temporalmente el botón
            saleButton.innerHTML = '✅ VENTA REGISTRADA';
            saleButton.style.background = 'linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%)';
            
            // Restaurar después de 500ms
            setTimeout(() => {
                saleButton.innerHTML = originalText;
                saleButton.style.background = 'linear-gradient(135deg, #4CAF50 0%, #45a049 100%)';
            }, 500);
        }

        // Actualizar todos los displays
        function updateDisplays() {
            document.getElementById('totalItems').textContent = systemState.totalItems;
            document.getElementById('salesCount').textContent = systemState.salesCount;
            document.getElementById('totalRevenue').textContent = `$${systemState.totalRevenue.toLocaleString()}`;
            
            // Actualizar total en modal
            document.getElementById('modalTotal').textContent = `$${systemState.totalRevenue.toLocaleString()}`;
        }

        // Agregar transacción al registro visual
        function addTransactionToDisplay(timestamp) {
            const transactionList = document.getElementById('transactionList');
            const transactionItem = document.createElement('div');
            transactionItem.className = 'transaction-item';
            
            transactionItem.innerHTML = `
                <div class="transaction-time">${timestamp}</div>
                <div class="transaction-details">
                    <div class="transaction-type">VENTA - 1 Prenda</div>
                </div>
                <div class="transaction-amount">+$10.000</div>
            `;
            
            // Agregar al inicio de la lista
            transactionList.insertBefore(transactionItem, transactionList.firstChild);
            
            // Limitar a 15 transacciones visibles
            if (transactionList.children.length > 15) {
                transactionList.removeChild(transactionList.lastChild);
            }
        }

        // Agregar entrada al registro de auditoría
        function addAuditLog(message) {
            const auditLog = document.getElementById('auditLog');
            const now = new Date().toLocaleTimeString();
            const logItem = document.createElement('div');
            logItem.className = 'audit-item';
            logItem.textContent = `[${now}] ${message}`;
            
            auditLog.insertBefore(logItem, auditLog.firstChild);
            
            // Limitar a 10 entradas
            if (auditLog.children.length > 10) {
                auditLog.removeChild(auditLog.lastChild);
            }
            
            // Guardar en estado
            systemState.auditLog.unshift(`[${now}] ${message}`);
        }

        // Mostrar modal de reinicio
        function showResetModal() {
            // Actualizar total en modal
            document.getElementById('modalTotal').textContent = `$${systemState.totalRevenue.toLocaleString()}`;
            document.getElementById('resetModal').style.display = 'flex';
        }

        // Ocultar modal de reinicio
        function hideResetModal() {
            document.getElementById('resetModal').style.display = 'none';
        }

        // Reiniciar sistema desde modal
        function confirmReset() {
            const securityKey = prompt('Para reiniciar el sistema, ingrese la clave de seguridad (1234):');
            
            if (securityKey === '1234') {
                resetSystem();
                hideResetModal();
            } else {
                alert('❌ Clave de seguridad incorrecta');
                addAuditLog('Intento de reinicio fallido - Clave incorrecta');
            }
        }

        // Reiniciar sistema
        function resetSystem() {
            // Registrar en auditoría
            addAuditLog('SISTEMA REINICIADO - Nuevo día iniciado');
            
            // Resetear estado
            systemState = {
                totalItems: 0,
                availableItems: 100,
                salesCount: 0,
                totalRevenue: 0,
                transactionHistory: [],
                auditLog: systemState.auditLog.slice(0, 10), // Mantener último log
                lastTransaction: null
            };
            
            // Limpiar displays
            updateDisplays();
            document.getElementById('transactionList').innerHTML = '';
            
            // Actualizar fecha
            const now = new Date();
            document.getElementById('currentDate').textContent = 
                now.toLocaleDateString('es-ES', { 
                    weekday: 'long', 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
            
            // Agregar mensaje inicial
            addAuditLog('Sistema reiniciado - Listo para registrar ventas');
            
            // Guardar estado limpio
            saveData();
            
            alert('✅ Sistema reiniciado correctamente');
        }

        // Guardar datos en localStorage
        function saveData() {
            try {
                localStorage.setItem('todo10000_simple', JSON.stringify(systemState));
            } catch (e) {
                console.error('Error guardando datos:', e);
            }
        }

        // Cargar datos guardados
        function loadSavedData() {
            try {
                const saved = localStorage.getItem('todo10000_simple');
                if (saved) {
                    const parsed = JSON.parse(saved);
                    
                    // Verificar que sea del mismo día (simplificado)
                    systemState = parsed;
                    
                    // Reconstruir displays de transacciones
                    document.getElementById('transactionList').innerHTML = '';
                    parsed.transactionHistory.slice(-15).reverse().forEach(trans => {
                        addTransactionToDisplay(trans.timestamp);
                    });
                    
                    // Reconstruir auditoría
                    document.getElementById('auditLog').innerHTML = '';
                    parsed.auditLog.slice(0, 10).forEach(log => {
                        const logItem = document.createElement('div');
                        logItem.className = 'audit-item';
                        logItem.textContent = log;
                        document.getElementById('auditLog').appendChild(logItem);
                    });
                    
                    addAuditLog('Datos del día cargados exitosamente');
                }
            } catch (e) {
                console.error('Error cargando datos:', e);
            }
        }

        // Función para ir al reporte diario
        function irAReporteDiario() {
            // Verificar si hay ventas registradas
            if (systemState.totalRevenue > 0) {
                const confirmar = confirm(
                    `Tiene ventas registradas por un total de $${systemState.totalRevenue.toLocaleString()}.\n\n` +
                    `¿Desea continuar al reporte diario para registrar los gastos?\n\n` +
                    `Nota: Las ventas quedarán guardadas en el sistema.`
                );
                if (!confirmar) return;
                
                // Guardar datos antes de salir
                saveData();
                addAuditLog('Redirección a reporte diario - Ventas guardadas');
            } else {
                const confirmar = confirm('¿Desea ir al reporte diario para registrar los gastos del día?');
                if (!confirmar) return;
            }
            
            // Redirigir a la vista de reporte diario
            window.location.href = '/Reportes/ReporteDiario';
        }

        // Inicializar sistema cuando se carga la página
        document.addEventListener('DOMContentLoaded', initSystem);

        // Atajo de teclado: Espacio para registrar venta
        document.addEventListener('keydown', function(event) {
            if (event.code === 'Space' || event.code === 'Enter') {
                event.preventDefault();
                registerSale();
            }
        });

        // Prevenir recarga accidental
        window.addEventListener('beforeunload', function (e) {
            if (systemState.transactionHistory.length > 0) {
                e.preventDefault();
                e.returnValue = 'Tiene ventas registradas. ¿Está seguro de querer salir?';
            }
        });
    </script>
</body>
</html>