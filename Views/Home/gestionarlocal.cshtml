        async function updateUsuario(usuarioId) {
            const usuario = systemData.usuarios.find(u => u.id === usuarioId);
            if (!usuario) return;

            const localId = parseInt(document.getElementById('editLocalId').value) || null;
            const local = localId ? systemData.locales.find(l => l.id === localId) : null;

            const updatedUsuario = {
                nombre: document.getElementById('editNombre').value.trim(),
                apellido: document.getElementById('editApellido').value.trim(),
                telefono: document.getElementById('editTelefono').value.trim(),
                direccion: document.getElementById('editDireccion').value.trim(),
                cargo: document.getElementById('editCargo').value,
                local_id: localId
            };

            // Validar campos requeridos
            if (!updatedUsuario.nombre || !updatedUsuario.apellido || !updatedUsuario.cargo || !localId) {
                alert('Por favor complete todos los campos requeridos');
                return;
            }

            try {
                const token = getCsrfToken();
                
                const response = await fetch(`${API_BASE_URL}/usuarios/${usuarioId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(updatedUsuario)
                });

                if (response.ok) {
                    Object.assign(usuario, updatedUsuario);
                    usuario.local_nombre = local ? local.nombre : '';
                    renderUsuarios();
                    updateDashboard();
                    closeEditModal();
                    alert('✅ Usuario actualizado correctamente');
                } else {
                    const error = await response.json();
                    alert(`Error al actualizar: ${error.error || 'Error desconocido'}`);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error de conexión con el servidor');
            }
        }

        // =====================================================
        // MOSTRAR MODAL DE ELIMINACIÓN
        // =====================================================
        function showDeleteModal(type, id) {
            let item, message;
            
            if (type === 'local') {
                item = systemData.locales.find(l => l.id === id);
                if (!item) return;
                
                // Verificar si el local tiene usuarios asignados
                const tieneUsuarios = systemData.usuarios.some(u => u.local_id === id);
                
                message = `¿Está seguro de eliminar el local:<br><strong>${item.nombre}</strong><br>${item.direccion}, ${item.ciudad}`;
                
                if (tieneUsuarios) {
                    message += `<br><br><span style="color: #f44336;">⚠️ Advertencia: Este local tiene usuarios asignados.</span>`;
                }
            } else if (type === 'usuario') {
                item = systemData.usuarios.find(u => u.id === id);
                if (!item) return;
                message = `¿Está seguro de eliminar el usuario:<br><strong>${item.nombre} ${item.apellido}</strong><br>Usuario: ${item.usuario}<br>Cargo: ${item.cargo}`;
            }

            document.getElementById('deleteMessage').innerHTML = `
                ${message}<br><br>
                <span style="color: #f44336;">⚠️ Esta acción no se puede deshacer.</span>
            `;
            
            document.getElementById('deleteModal').dataset.type = type;
            document.getElementById('deleteModal').dataset.id = id;
            document.getElementById('deleteModal').style.display = 'flex';
        }

        // =====================================================
        // CONFIRMAR ELIMINACIÓN
        // =====================================================
        async function confirmDelete() {
            const type = document.getElementById('deleteModal').dataset.type;
            const id = parseInt(document.getElementById('deleteModal').dataset.id);
            
            try {
                const endpoint = type === 'local' ? 'locales' : 'usuarios';
                const token = getCsrfToken();
                
                const response = await fetch(`${API_BASE_URL}/${endpoint}/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (response.ok) {
                    if (type === 'local') {
                        systemData.locales = systemData.locales.filter(l => l.id !== id);
                        renderLocals();
                        loadLocalesSelect();
                    } else if (type === 'usuario') {
                        systemData.usuarios = systemData.usuarios.filter(u => u.id !== id);
                        renderUsuarios();
                    }
                    
                    updateDashboard();
                    closeDeleteModal();
                    alert('✅ Eliminado correctamente');
                } else {
                    const error = await response.json();
                    alert(`Error al eliminar: ${error.error || 'Error desconocido'}`);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error de conexión con el servidor');
            }
        }

        // =====================================================
        // OBTENER TOKEN CSRF
        // =====================================================
        function getCsrfToken() {
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            return tokenInput ? tokenInput.value : '';
        }

        // =====================================================
        // BUSCAR LOCALES
        // =====================================================
        function searchLocals() {
            const searchTerm = document.getElementById('searchLocals').value.toLowerCase();
            const cards = document.querySelectorAll('#localsContainer .card');
            
            let visibleCount = 0;
            
            cards.forEach(card => {
                const text = card.textContent.toLowerCase();
                const isVisible = text.includes(searchTerm);
                card.style.display = isVisible ? 'block' : 'none';
                if (isVisible) visibleCount++;
            });
            
            // Mostrar mensaje si no hay resultados
            const container = document.getElementById('localsContainer');
            let noResults = container.querySelector('.no-results');
            
            if (visibleCount === 0 && cards.length > 0) {
                if (!noResults) {
                    noResults = document.createElement('div');
                    noResults.className = 'empty-state no-results';
                    noResults.innerHTML = `
                        <div style="font-size: 48px; margin-bottom: 20px;">🔍</div>
                        <h3>No se encontraron resultados</h3>
                        <p>Intenta con otros términos de búsqueda</p>
                    `;
                    container.appendChild(noResults);
                }
                noResults.style.display = 'block';
            } else if (noResults) {
                noResults.style.display = 'none';
            }
        }

        // =====================================================
        // BUSCAR USUARIOS
        // =====================================================
        function searchUsuarios() {
            const searchTerm = document.getElementById('searchUsuarios').value.toLowerCase();
            const cards = document.querySelectorAll('#usuariosContainer .card');
            
            let visibleCount = 0;
            
            cards.forEach(card => {
                const text = card.textContent.toLowerCase();
                const isVisible = text.includes(searchTerm);
                card.style.display = isVisible ? 'block' : 'none';
                if (isVisible) visibleCount++;
            });
            
            // Mostrar mensaje si no hay resultados
            const container = document.getElementById('usuariosContainer');
            let noResults = container.querySelector('.no-results');
            
            if (visibleCount === 0 && cards.length > 0) {
                if (!noResults) {
                    noResults = document.createElement('div');
                    noResults.className = 'empty-state no-results';
                    noResults.innerHTML = `
                        <div style="font-size: 48px; margin-bottom: 20px;">🔍</div>
                        <h3>No se encontraron resultados</h3>
                        <p>Intenta con otros términos de búsqueda</p>
                    `;
                    container.appendChild(noResults);
                }
                noResults.style.display = 'block';
            } else if (noResults) {
                noResults.style.display = 'none';
            }
        }

        // =====================================================
        // ACTUALIZAR DASHBOARD
        // =====================================================
        function updateDashboard() {
            document.getElementById('totalLocals').textContent = systemData.locales.length;
            document.getElementById('totalUsuarios').textContent = systemData.usuarios.length;
            
            const today = new Date().toISOString().split('T')[0];
            const totalInv = systemData.inventario
                .filter(inv => inv.fecha === today)
                .reduce((sum, inv) => sum + inv.inv_final, 0);
            document.getElementById('totalInventario').textContent = totalInv.toLocaleString();
        }

        // =====================================================
        // MOSTRAR ALERTA
        // =====================================================
        function showAlert(containerId, message, type) {
            const container = document.getElementById(containerId);
            container.textContent = message;
            container.className = `alert alert-${type}`;
            container.style.display = 'block';
            
            // Desplazar hacia la alerta
            container.scrollIntoView({ behavior: 'smooth', block: 'center' });
            
            setTimeout(() => {
                container.style.display = 'none';
            }, 5000);
        }

        // =====================================================
        // LIMPIAR FORMULARIOS
        // =====================================================
        function clearUsuarioForm() {
            document.getElementById('usuarioNombre').value = '';
            document.getElementById('usuarioApellido').value = '';
            document.getElementById('usuarioTelefono').value = '';
            document.getElementById('usuarioDireccion').value = '';
            document.getElementById('usuarioCargo').value = '';
            document.getElementById('usuarioUser').value = '';
            document.getElementById('usuarioPassword').value = '';
            document.getElementById('usuarioLocalId').value = '';
            document.getElementById('usuarioAlert').style.display = 'none';
        }

        function clearLocalForm() {
            document.getElementById('localNombre').value = '';
            document.getElementById('localDireccion').value = '';
            document.getElementById('localCiudad').value = '';
            document.getElementById('localTelefono').value = '';
            document.getElementById('localEstado').value = 'ACTIVO';
            document.getElementById('localAlert').style.display = 'none';
        }

        function clearInventarioForm() {
            document.getElementById('invLocalId').value = '';
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('invFecha').value = today;
            document.getElementById('invInicial').value = '';
            document.getElementById('invEntrada').value = '0';
            document.getElementById('invSalida').value = '0';
            document.getElementById('invFinal').value = '';
            document.getElementById('inventarioAlert').style.display = 'none';
        }

        // =====================================================
        // CERRAR MODALES
        // =====================================================
        function closeDetailModal() {
            document.getElementById('detailModal').style.display = 'none';
        }

        function closeEditModal() {
            document.getElementById('editModal').style.display = 'none';
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
        }

        // =====================================================
        // CERRAR MODALES AL HACER CLIC FUERA
        // =====================================================
        window.onclick = function(event) {
            const detailModal = document.getElementById('detailModal');
            const editModal = document.getElementById('editModal');
            const deleteModal = document.getElementById('deleteModal');
            
            if (event.target === detailModal) {
                closeDetailModal();
            }
            if (event.target === editModal) {
                closeEditModal();
            }
            if (event.target === deleteModal) {
                closeDeleteModal();
            }
        }

        // =====================================================
        // INICIALIZAR AL CARGAR LA PÁGINA
        // =====================================================
        document.addEventListener('DOMContentLoaded', initSystem);
    </script>

    @* Token CSRF para seguridad *@
    @Html.AntiForgeryToken()
</body>
</html>