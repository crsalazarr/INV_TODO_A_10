                ciudad: document.getElementById('localCiudad').value.trim(),
                telefono: document.getElementById('localTelefono').value.trim(),
                estado: document.getElementById('localEstado').value
            };

            try {
                const token = getCsrfToken();
                
                const response = await fetch(`${API_BASE_URL}/locales`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(nuevoLocal)
