        // =====================================================
        // ACTUALIZAR LOCAL
        // =====================================================
        async function updateLocal(localId) {
            const local = systemData.locales.find(l => l.id === localId);
            if (!local) return;

            const updatedLocal = {
                nombre: document.getElementById('editNombre').value.trim(),
                direccion: document.getElementById('editDireccion').value.trim(),
                ciudad: document.getElementById('editCiudad').value.trim(),
                telefono: document.getElementById('editTelefono').value.trim(),
                estado: document.getElementById('editEstado').value
            };

            // Validar campos requeridos
            if (!updatedLocal.nombre || !updatedLocal.direccion || !updatedLocal.ciudad) {
                alert('Por favor complete todos los campos requeridos');
                return;
            }

            try {
                const token = getCsrfToken();
                
                const response = await fetch(`${API_BASE_URL}/locales/${localId}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(updatedLocal)
                });

                if (response.ok) {
                    Object.assign(local, updatedLocal);
                    renderLocals();
                    loadLocalesSelect();
                    updateDashboard();
                    closeEditModal();
                    alert('✅ Local actualizado correctamente');
                } else {
                    const error = await response.json();
                    alert(`Error al actualizar: ${error.error || 'Error desconocido'}`);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error de conexión con el servidor');
            }
        }

