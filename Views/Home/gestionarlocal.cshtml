        function loadLocalesSelect() {
            const selects = ['usuarioLocalId', 'invLocalId'];
            
            selects.forEach(selectId => {
                const select = document.getElementById(selectId);
                const currentValue = select.value;
                select.innerHTML = '<option value="">Seleccione un local</option>';
                
                // Ordenar locales por nombre
                const localesOrdenados = [...systemData.locales].sort((a, b) => 
                    a.nombre.localeCompare(b.nombre)
                );
                
                localesOrdenados.forEach(local => {
                    if (local.estado === 'ACTIVO') {
                        const option = document.createElement('option');
                        option.value = local.id;
                        option.textContent = `${local.nombre} - ${local.ciudad}`;
                        select.appendChild(option);
                    }
                });
                
                // Mantener el valor actual si existe
                if (currentValue) {
                    select.value = currentValue;
                }
            });
        }

