        // =====================================================
      async function saveInventario() {
    console.log('Guardando inventario...');

    const requiredFields = ['invLocalId', 'invFecha', 'invInicial', 'invFinal'];

    // ✅ VALIDACIÓN CORRECTA (ACEPTA 0)
    for (const field of requiredFields) {
        const input = document.getElementById(field);
        const value = input.value;

        if (value === '' || value === null) {
            showAlert(
                'inventarioAlert',
                `Por favor complete el campo: ${input.previousElementSibling.textContent}`,
                'error'
            );
            input.focus();
            return;
        }
    }

    // ✅ OBJETO LIMPIO Y CORRECTO
    const nuevoInventario = {
        fecha: document.getElementById('invFecha').value,
        local_id: Number(document.getElementById('invLocalId').value),
        inv_inicial: Number(document.getElementById('invInicial').value),
        entrada: Number(document.getElementById('invEntrada').value) || 0,
        salida: Number(document.getElementById('invSalida').value) || 0,
        inv_final: Number(document.getElementById('invFinal').value)
    };

    // ✅ VALIDACIÓN FINAL
    if (nuevoInventario.inv_final < 0) {
        showAlert(
            'inventarioAlert',
            'El inventario final no puede ser negativo',
            'error'
        );
        return;
    }

    try {
        const token = getCsrfToken();

        const response = await fetch(`${API_BASE_URL}/inventario`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(nuevoInventario)
        });

        if (response.ok) {
            const data = await response.json();
            nuevoInventario.id = data.id;

            systemData.inventario.push(nuevoInventario);

            showAlert(
                'inventarioAlert',
                '✅ Inventario registrado exitosamente',
                'success'
            );

            updateDashboard();

            setTimeout(() => {
                clearInventarioForm();
                switchTab('dashboard');
            }, 1200);
        } else {
            const error = await response.json();
            showAlert(
                'inventarioAlert',
                `Error al guardar el inventario: ${error.error || 'Error desconocido'}`,
                'error'
            );
        }
    } catch (error) {
        console.error(error);
        showAlert(
            'inventarioAlert',
            '❌ Error de conexión con el servidor',
            'error'
        );
    }
}


        // =====================================================
        // CALCULAR INVENTARIO FINAL
        // =====================================================
       function calcularInventarioFinal() {
    const inicial = Number(document.getElementById('invInicial').value) || 0;
    const entrada = Number(document.getElementById('invEntrada').value) || 0;
    const salida  = Number(document.getElementById('invSalida').value) || 0;

    const final = inicial + entrada - salida;

    document.getElementById('invFinal').value = final;
}


        // =====================================================
        // CARGAR INVENTARIO ANTERIOR
        // =====================================================
        async function loadInventarioAnterior() {
            const localId = parseInt(document.getElementById('invLocalId').value);
            if (!localId) return;

            try {
                const response = await fetch(`${API_BASE_URL}/inventario/ultimo/${localId}`);
                if (response.ok) {
                    const ultimo = await response.json();
                    if (ultimo && !ultimo.error) {
                        document.getElementById('invInicial').value = ultimo.inv_final;
                        calcularInventarioFinal();
                    }
                }
            } catch (error) {
                console.error('Error al cargar inventario anterior:', error);
            }
        }

